# Copy this file into a private capture workspace and replace placeholders.
export ANDROID_USER="10"
export TEST_ID="example-controlled-voice-canary-r1"
export TEST_ROOT="/PRIVATE/PATH/OUTSIDE/THE/REPOSITORY/$TEST_ID"
export PCAP_NAME="$TEST_ID.pcap"
export KEYLOG_NAME="$TEST_ID.sslkeylog"
export CSV_NAME="$TEST_ID-connections.csv"
export LOGCAT_NAME="$TEST_ID-logcat.txt"
